# Copy this to .env for local runs. NEVER commit the real .env file.
# .gitignore already excludes it.

# Which Kalshi environment to hit
# - demo: https://demo-api.kalshi.co (fake money, what paper.py uses)
# - prod: https://api.elections.kalshi.com (real money, what live.py uses)
KALSHI_ENV=demo

# Your API key ID from Kalshi -> Settings -> API Keys -> Create new API key
KALSHI_API_KEY_ID=

# Local path to the RSA private key file Kalshi gave you when you created
# the key. Keep this file outside the repo if possible.
KALSHI_PRIVATE_KEY_PATH=~/.kalshi/kalshi_demo.pem
